DJANGO_SETTINGS_MODULE=clothing_store.settings.production
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Cloudflare R2 (optional if using local storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
R2_PUBLIC_DOMAIN=
R2_REGION=auto

# Cache
REDIS_URL=
DISABLE_CACHE=True

# Feature flags
FEATURE_OTP_VERIFICATION=False
FEATURE_FAST_DELIVERY=False
FEATURE_BANK_TRANSFER=False
FEATURE_CARD_PAYMENT=False
FEATURE_APP_ICON=False
FEATURE_NEW_ARRIVALS_SECTION=True
FEATURE_ADS_SECTION=True
OWNER_DASHBOARD_REPORTS=True

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Contact
CONTACT_EMAIL=support@example.com
