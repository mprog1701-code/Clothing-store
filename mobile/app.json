{
  "expo": {
    "name": "دار DAAR",
    "slug": "daar",
    "version": "1.0.1",
    "orientation": "portrait",
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0,
      "useEmbeddedUpdate": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daar.app",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {},
      "package": "com.daar.app",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "https://clothing-store-production-4387.up.railway.app",
      "loginUrl": "https://clothing-store-production-4387.up.railway.app/login/",
      "googleOauthStartUrl": "https://clothing-store-production-4387.up.railway.app/login/?provider=google",
      "googleAndroidClientId": "",
      "googleIosClientId": ""
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow DAAR to access your location for address detection."
        }
      ]
    ]
  }
}
